digraph G {
  graph [bgcolor="#FBF7EF", pad="0.34", nodesep="0.40", ranksep="0.48", splines=polyline, fontname="PingFang SC", rankdir=TB];
  node [shape=box, style="rounded,filled", fillcolor="#FFFFFF", color="#0F5961", penwidth=1.8, fontname="PingFang SC", fontcolor="#18363A", fontsize=17, margin="0.20,0.14"];
  edge [color="#0F5961", penwidth=1.8, arrowsize=0.8, fontname="PingFang SC", fontcolor="#18363A", fontsize=12];

  start [label="商机确认\n9:12", fillcolor="#0F5961", fontcolor="#FFFFFF"];
  move [label="搬运\n聊天、转写、CRM\n19 分钟"];
  search [label="查找＋等待\n模板、版本、产品确认\n47 分钟"];
